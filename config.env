# PeakForm — Environment Configuration Template
# COPY THIS FILE AND RENAME IT TO .env
# DO NOT PASTE SECRETS IN THIS FILE (it is uploaded to Git)
# Paste your secrets into the .env file instead.

SECRET_KEY=
DATABASE_PATH=database/peakform.db
FLASK_PORT=5000
FLASK_ENV=development

GEMINI_API_KEY=
GEMINI_SECONDARY_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

ADMIN_EMAIL=admin@peakform.app
ADMIN_PASSWORD=Admin@1234
