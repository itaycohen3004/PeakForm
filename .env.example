# PeakForm — Environment Configuration Template
# Copy this file to .env and fill in your secrets.

# Flask / Security
# A long, random string used for JWT signing and session encryption. 
# Automatically generated by setup.py if not provided.
SECRET_KEY=generate_me_locally

# Database
DATABASE_PATH=database/peakform.db

# Server Config
FLASK_PORT=5000
FLASK_ENV=development

# AI Coach (Optional but recommended)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Default Admin Account
# These will be used to create the admin user automatically on first run.
ADMIN_EMAIL=admin@peakform.app
ADMIN_PASSWORD=Admin@1234
